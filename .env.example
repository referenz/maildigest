# .env.example – Konfiguration für email_summary.ts
# Kopieren nach ".env" und Werte eintragen.
# WICHTIG: Die .env-Datei niemals in ein Git-Repository committen!
# Sicherstellen, dass ".env" in der .gitignore steht.

# -------------------------------------------------------------------
# Pflichtfelder
# -------------------------------------------------------------------

# Gmail-Account (Quelle der abzurufenden E-Mails)
GMAIL_USER=dein.name@gmail.com

# 16-stelliges App-Passwort (ohne Leerzeichen)
# Erstellen unter: Google-Konto → Sicherheit → 2-Schritt-Verifizierung → App-Passwörter
GMAIL_APP_PW=xxxxxxxxxxxxxx

# Zieladresse für die Zusammenfassung (kann dieselbe wie GMAIL_USER sein)
TARGET_EMAIL=zusammenfassung@example.com

# Anthropic API-Key
# Erstellen unter: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# -------------------------------------------------------------------
# Optionale Felder (Standardwerte sind bereits gesetzt)
# -------------------------------------------------------------------

# Wie viele Tage zurückschauen (1 = seit gestern)
# DAYS_BACK=1

# Gmail-Ordner, der ausgelesen wird
# Weitere Beispiele: "[Gmail]/Gesendet", "[Gmail]/Markiert"
# IMAP_FOLDER=INBOX

# Maximale Anzahl E-Mails pro Lauf (Kostenkontrolle)
# MAX_EMAILS=50

# Pfad zur State-Datei (speichert Zeitstempel und E-Mail-Anzahl des letzten Laufs)
# STATE_FILE=./email_summary_state.json
